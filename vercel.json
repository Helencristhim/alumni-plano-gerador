{
  "version": 2,
  "github": {
    "silent": true
  },
  "buildCommand": "node scripts/build-lesson-counts.js || true; python3 scripts/check_lesson_integrity.py || true; node scripts/check_audiomap_syntax.js || true",
  "outputDirectory": "public",
  "functions": {
    "api/perfil-360.js": {
      "maxDuration": 800
    },
    "api/gerar-plano.js": {
      "maxDuration": 300
    },
    "api/assistente.js": {
      "maxDuration": 300
    },
    "api/gerar-temas.js": {
      "maxDuration": 800
    },
    "api/save-perfil.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/lib/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
