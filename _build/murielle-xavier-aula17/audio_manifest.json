  "file": "a17_only_a_little_time_we_have_a_few_weeks_not_enoug.mp3"
 },
 {
  "text": "Do we have enough candidates in the pipeline?",
  "voice": "arthur",
  "file": "a17_do_we_have_enough_candidates_in_the_pipeline.mp3"
 },
 {
  "text": "We have plenty of candidates, but only a handful are qualified.",
