 },
 {
  "text": "Murielle, how many vacancies do we have this quarter?",
  "voice": "arthur",
  "file": "a17_murielle_how_many_vacancies_do_we_have_this_quar.mp3"
 },
 {
  "text": "We have many vacancies, but we do not have much budget to fill them.",
  "voice": "ellen",
  "file": "a17_we_have_many_vacancies_but_we_do_not_have_much_b.mp3"
 },
 {
  "text": "How much time do we have before the deadline?",
  "voice": "arthur",
  "file": "a17_how_much_time_do_we_have_before_the_deadline.mp3"
 },
 {
  "text": "Only a little time. We have a few weeks, not enough for a full search.",
