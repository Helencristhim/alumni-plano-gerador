 },
 {
  "text": "Welcome back, Fernando. Shall we negotiate the terms of our partnership?",
  "voice": "ellen",
  "file": "a12_welcome_back_fernando_shall_we_negotiate_the_ter.mp3"
 },
 {
  "text": "Yes, thank you. I would suggest a two-year deal to start.",
  "voice": "arthur",
  "file": "a12_yes_thank_you_i_would_suggest_a_two_year_deal_to.mp3"
 },
 {
  "text": "That sounds fair. What is your proposal for the price?",
  "voice": "ellen",
  "file": "a12_that_sounds_fair_what_is_your_proposal_for_the_p.mp3"
 },
 {
  "text": "If we agree on the price today, we can sign this week.",
  "voice": "arthur",
  "file": "a12_if_we_agree_on_the_price_today_we_can_sign_this.mp3"
 },
 {
  "text": "I like your offer, but I cannot accept the full amount.",
  "voice": "ellen",
  "file": "a12_i_like_your_offer_but_i_cannot_accept_the_full_a.mp3"
 },
 {
  "text": "I understand. Would you accept a small compromise?",
  "voice": "arthur",
  "file": "a12_i_understand_would_you_accept_a_small_compromise.mp3"
 },
 {
  "text": "Yes. If you reduce the price, I will accept the deal.",
  "voice": "ellen",
  "file": "a12_yes_if_you_reduce_the_price_i_will_accept_the_de.mp3"
 },
 {
  "text": "Then we agree. It is a fair deal for both of us.",
  "voice": "arthur",
  "file": "a12_then_we_agree_it_is_a_fair_deal_for_both_of_us.mp3"
 },
 {
  "text": "It is a fair deal for both of us.",
