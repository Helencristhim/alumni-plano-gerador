 {
  "text": "Good morning. I am Mr. Lopez, a visitor from Sao Paulo.",
  "voice": "arthur",
  "file": "a16_good_morning_i_am_mr_lopez_a_visitor_from_sao_pa.mp3"
 },
 {
  "text": "Welcome, Mr. Lopez. Please come in.",
  "voice": "ellen",
  "file": "a16_welcome_mr_lopez_please_come_in.mp3"
 },
 {
  "text": "Thank you. This is a beautiful reception.",
  "voice": "arthur",
  "file": "a16_thank_you_this_is_a_beautiful_reception.mp3"
 },
 {
  "text": "Please, have a seat. Would you like a coffee?",
  "voice": "ellen",
  "file": "a16_please_have_a_seat_would_you_like_a_coffee.mp3"
 },
 {
  "text": "A coffee, please. Where is the meeting?",
  "voice": "arthur",
  "file": "a16_a_coffee_please_where_is_the_meeting.mp3"
 },
 {
  "text": "Follow me, please. Let me introduce you to my team.",
  "voice": "ellen",
  "file": "a16_follow_me_please_let_me_introduce_you_to_my_team.mp3"
 },
 {
  "text": "Hello, good morning. My name is Mr. Lopez. I am a visitor from the Sao Paulo office. I have a meeting with Anna Miranda at ten. This is a beautiful building. The reception is very nice. I am a little early, so I can wait in the lobby. Thank you very much.",
  "voice": "arthur",
  "file": "a16_listening1.mp3"
 },
 {
  "text": "Today a visitor came to my office. His name is Mr. Lopez. I went to the reception and I said, welcome, please come in. I took him to the lobby and I said, have a seat. Then I said, would you like a coffee or a water? He said a coffee, please. After that, I took the elevator to the third floor and I introduced him to my team. I am a good host now.",
  "voice": "ellen",
  "file": "a16_listening2.mp3"
 },
 {
  "text": "First, the visitor arrives at the reception. Then Anna says, welcome, please come in. Next, she takes him to the lobby and says, have a seat. After that, she offers a coffee. Finally, she takes the elevator and introduces the guest to her team.",
  "voice": "arthur",
  "file": "pc16_order_visitor.mp3"
 },
