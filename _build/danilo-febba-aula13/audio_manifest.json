 },
 {
  "text": "Hi Danilo, it is Rachel. Can you hear me? The line is a little bad.",
  "voice": "ellen",
  "file": "a13_hi_danilo_it_is_rachel_can_you_hear_me_the_line.mp3"
 },
 {
  "text": "Now I can hear you. How can I help you, Rachel?",
  "voice": "arthur",
  "file": "a13_now_i_can_hear_you_how_can_i_help_you_rachel.mp3"
 },
 {
  "text": "I am calling about the report. Could you send it today?",
  "voice": "ellen",
  "file": "a13_i_am_calling_about_the_report_could_you_send_it.mp3"
 },
 {
  "text": "Of course. Could you hold on for one minute, please?",
  "voice": "arthur",
  "file": "a13_of_course_could_you_hold_on_for_one_minute_pleas.mp3"
 },
 {
  "text": "Sure, no problem. I will hold.",
  "voice": "ellen",
  "file": "a13_sure_no_problem_i_will_hold.mp3"
 },
 {
  "text": "Thank you. I am sending it now. Can you check your email?",
  "voice": "arthur",
  "file": "a13_thank_you_i_am_sending_it_now_can_you_check_your.mp3"
 },
 {
  "text": "Got it. If I have a question, can I call you back later?",
  "voice": "ellen",
  "file": "a13_got_it_if_i_have_a_question_can_i_call_you_back.mp3"
 },
 {
  "text": "Of course. If I do not pick up, just leave a message. Bye, Rachel!",
  "voice": "arthur",
  "file": "a13_of_course_if_i_do_not_pick_up_just_leave_a_messa.mp3"
 },
 {
  "text": "Hello, this is Danilo speaking.",
  "voice": "ellen",
  "file": "a13_hello_this_is_danilo_speaking.mp3"
 },
 {
  "text": "Sorry, the line is bad. Can you call me back?",
  "voice": "arthur",
  "file": "a13_sorry_the_line_is_bad_can_you_call_me_back.mp3"
 },
 {
  "text": "Hi Danilo, this is Rachel. I am calling about the client meeting on Friday. I tried to call you this morning, but I could not reach you. Could you call me back today? You can also send me a short message if you are in a meeting right now. If I do not pick up, please leave a voicemail, and I will call you back. Thank you so much, and talk soon. Bye!",
  "voice": "ellen",
  "file": "a13_listening_voicemail.mp3"
 },
 {
  "text": "Hi, you have reached Danilo Febba, Data Engineering Lead. I am sorry I cannot take your call right now. I am probably in a meeting or running a data pipeline. Please leave your name, your number, and a short message after the tone. You can also send me an email, and I will get back to you today. Thank you for calling. Have a great day!",
  "voice": "arthur",
  "file": "a13_listening_greeting.mp3"
 },
