 },
 {
  "text": "Hello, welcome to the store! Can I help you?",
  "voice": "arthur",
  "file": "a10_hello_welcome_to_the_store_can_i_help_you.mp3"
 },
 {
  "text": "Yes, please. How much is this blue shirt? What is the price?",
  "voice": "ellen",
  "file": "a10_yes_please_how_much_is_this_blue_shirt_what_is_t.mp3"
 },
 {
  "text": "The blue shirt is forty reais. It is a good price, very cheap.",
  "voice": "arthur",
  "file": "a10_the_blue_shirt_is_forty_reais_it_is_a_good_price.mp3"
 },
 {
  "text": "That is cheap! How many colors do you have?",
  "voice": "ellen",
  "file": "a10_that_is_cheap_how_many_colors_do_you_have.mp3"
 },
 {
  "text": "We have four colors. What size do you want?",
  "voice": "arthur",
  "file": "a10_we_have_four_colors_what_size_do_you_want.mp3"
 },
 {
  "text": "I want a medium size. Can I pay with card?",
  "voice": "ellen",
  "file": "a10_i_want_a_medium_size_can_i_pay_with_card.mp3"
 },
 {
  "text": "Yes, you can pay with card or money. How many shirts do you want?",
  "voice": "arthur",
  "file": "a10_yes_you_can_pay_with_card_or_money_how_many_shir.mp3"
 },
 {
  "text": "Two shirts, please. I am happy to buy them today.",
  "voice": "ellen",
  "file": "a10_two_shirts_please_i_am_happy_to_buy_them_today.mp3"
 },
 {
  "text": "How much is this?",
  "voice": "ellen",
