 },
 {
  "text": "Graziele, can you help me with the meeting, please?",
  "voice": "arthur",
  "file": "a13_graziele_can_you_help_me_with_the_meeting_please.mp3"
 },
 {
  "text": "Of course. Can I bring the documents?",
  "voice": "ellen",
  "file": "a13_of_course_can_i_bring_the_documents.mp3"
 },
 {
  "text": "Yes, please. And could you carry my laptop?",
  "voice": "arthur",
  "file": "a13_yes_please_and_could_you_carry_my_laptop.mp3"
 },
 {
  "text": "Sure. Could you wait a moment, please?",
  "voice": "ellen",
  "file": "a13_sure_could_you_wait_a_moment_please.mp3"
 },
 {
  "text": "No problem. Could you explain the schedule to the new nurse?",
  "voice": "arthur",
  "file": "a13_no_problem_could_you_explain_the_schedule_to_the.mp3"
 },
 {
  "text": "Yes. Can you pass me the schedule, please?",
  "voice": "ellen",
  "file": "a13_yes_can_you_pass_me_the_schedule_please.mp3"
 },
 {
  "text": "Here you are. Could you follow me to room two?",
  "voice": "arthur",
  "file": "a13_here_you_are_could_you_follow_me_to_room_two.mp3"
 },
 {
  "text": "Of course. Can I help you with anything else?",
  "voice": "ellen",
  "file": "a13_of_course_can_i_help_you_with_anything_else.mp3"
 },
 {
  "text": "No, thank you. You are a great help, Graziele.",
  "voice": "arthur",
  "file": "a13_no_thank_you_you_are_a_great_help_graziele.mp3"
 },
 {
  "text": "You are welcome. It is a pleasure to help.",
  "voice": "ellen",
  "file": "a13_you_are_welcome_it_is_a_pleasure_to_help.mp3"
 },
 {
  "text": "Could you wait a moment, please?",
  "voice": "arthur",
  "file": "a13_could_you_wait_a_moment_please.mp3"
 },
 {
  "text": "Hello Graziele. I am in a meeting now, and I need a little help. Can you bring the documents to room two, please? And could you carry my laptop? It is on my desk. Please wait for me at the door at three. One more thing: could you explain the schedule to the new nurse? Thank you so much for your help.",
  "voice": "arthur",
  "file": "a13_listening1.mp3"
 },
 {
  "text": "Hi Graziele, this is Ana. A quick tip about polite requests. To ask for help, use Can you or Could you and a verb. Could you is softer and more polite than Can you. Always add please. Say: Could you help me, please? To offer help, say: Can I help you? Short, simple, and kind. You can do it!",
  "voice": "ellen",
  "file": "a13_listening2.mp3"
 },
 {
  "text": "Dr. Carter asks Graziele for help in the meeting. First, he says can you help me, please. Then he asks could you bring the documents. Next, he asks could you carry the laptop. After that, he says please wait at the door. Finally, he asks could you explain the schedule.",
  "voice": "arthur",
  "file": "pc13_order_l13.mp3"
 },
