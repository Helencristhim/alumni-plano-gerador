 {
  "text": "Hi Fernanda! Welcome to the team. Tell me, what is your role?",
  "voice": "arthur",
  "file": "a2_hi_fernanda_welcome_to_the_team_tell_me_what_is.mp3"
 },
 {
  "text": "Hi Daniel! My role is in the trading office. I work with suppliers.",
  "voice": "ellen",
  "file": "a2_hi_daniel_my_role_is_in_the_trading_office_i_wor.mp3"
 },
 {
  "text": "Great! Do you work with global clients too?",
  "voice": "arthur",
  "file": "a2_great_do_you_work_with_global_clients_too.mp3"
 },
 {
  "text": "Yes, I do. I help with export contracts for global clients.",
  "voice": "ellen",
  "file": "a2_yes_i_do_i_help_with_export_contracts_for_global.mp3"
 },
 {
  "text": "Nice. And your team? Is it in one office?",
  "voice": "arthur",
  "file": "a2_nice_and_your_team_is_it_in_one_office.mp3"
 },
 {
  "text": "No, my team is remote. We do not work in one office. We work from many countries.",
  "voice": "ellen",
  "file": "a2_no_my_team_is_remote_we_do_not_work_in_one_offic.mp3"
 },
 {
  "text": "Perfect. Coffee is a global commodity, so we all work together.",
  "voice": "arthur",
  "file": "a2_perfect_coffee_is_a_global_commodity_so_we_all_w.mp3"
 },
 {
