 },
 {
  "text": "Welcome to Usina Cururique, Mr. Costa. This is our sugar. It is white and very sweet.",
  "voice": "ellen",
  "file": "a9_welcome_to_usina_cururique_mr_costa_this_is_our.mp3"
 },
 {
  "text": "It looks very clean. Is it a natural product?",
  "voice": "arthur",
  "file": "a9_it_looks_very_clean_is_it_a_natural_product.mp3"
 },
 {
  "text": "Yes, it is natural and dry. We make it here from sugarcane.",
  "voice": "ellen",
  "file": "a9_yes_it_is_natural_and_dry_we_make_it_here_from_s.mp3"
 },
 {
  "text": "Very good. The bags are big. Are they heavy?",
  "voice": "arthur",
  "file": "a9_very_good_the_bags_are_big_are_they_heavy.mp3"
 },
 {
  "text": "Yes, the bags are heavy and strong. They are good for a long trip.",
  "voice": "ellen",
  "file": "a9_yes_the_bags_are_heavy_and_strong_they_are_good.mp3"
 },
 {
  "text": "Perfect. Your sugar is fresh and clean. I want to buy it.",
  "voice": "arthur",
  "file": "a9_perfect_your_sugar_is_fresh_and_clean_i_want_to.mp3"
 },
 {
  "text": "Welcome to Usina Cururique. This is our sugar. Our sugar is white, clean and very sweet. It is a natural product from sugarcane. We make it here, and we put it in heavy bags. The bags are strong and dry, so they are good for a long trip. We export our sugar to many countries, and we are proud of our product.",
  "voice": "ellen",
  "file": "a9_listening1.mp3"
 },
 {
  "text": "Hello, this is Mr. Costa from a coffee company in Italy. I am calling about your sugar. We want a sweet and natural product for our customers. The sugar must be white, clean and dry. We also need it in strong bags, because the trip is long. Please send me a sample this week. Thank you very much.",
  "voice": "arthur",
  "file": "a9_listening2.mp3"
 },
 {
  "text": "First, the factory cuts the sugarcane. Then the machines make the white sugar. Next, the workers put the sugar in heavy bags. After that, they check that the bags are clean and dry. Finally, the company sends the strong bags to other countries.",
  "voice": "arthur",
  "file": "pc9_order_sequence.mp3"
 },
