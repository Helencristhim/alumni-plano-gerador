 {
  "text": "Good morning, Anna. Your sugar is good, but the price is high.",
  "voice": "arthur",
  "file": "a17_good_morning_anna_your_sugar_is_good_but_the_pri.mp3"
 },
 {
  "text": "Good. We want fifty tons. What is your best offer?",
  "voice": "arthur",
