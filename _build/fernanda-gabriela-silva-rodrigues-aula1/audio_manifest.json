 {
  "text": "Hello! I don't think we have met. I am Daniel, from the Geneva office.",
  "voice": "arthur",
  "file": "a1_hello_i_don_t_think_we_have_met_i_am_daniel_from.mp3"
 },
 {
  "text": "Nice to meet you, Daniel! My name is Fernanda. I am from Brazil.",
  "voice": "ellen",
  "file": "a1_nice_to_meet_you_daniel_my_name_is_fernanda_i_am.mp3"
 },
 {
  "text": "Nice to meet you too. Where do you work?",
  "voice": "arthur",
  "file": "a1_nice_to_meet_you_too_where_do_you_work.mp3"
 },
 {
  "text": "I work at Sucafina. I work with coffee and international clients.",
  "voice": "ellen",
  "file": "a1_i_work_at_sucafina_i_work_with_coffee_and_intern.mp3"
 },
 {
  "text": "Great! I am a partner on the international team.",
  "voice": "arthur",
  "file": "a1_great_i_am_a_partner_on_the_international_team.mp3"
 },
 {
  "text": "Nice! Sucafina is a global coffee company.",
  "voice": "ellen",
  "file": "a1_nice_sucafina_is_a_global_coffee_company.mp3"
 },
 {
  "text": "Yes! Can I send you an email about a new contract?",
  "voice": "arthur",
  "file": "a1_yes_can_i_send_you_an_email_about_a_new_contract.mp3"
 },
 {
  "text": "Yes, of course. Thank you, Daniel. Nice to meet you!",
  "voice": "ellen",
  "file": "a1_yes_of_course_thank_you_daniel_nice_to_meet_you.mp3"
 },
 {
  "text": "Good morning, everyone, and welcome to the International Coffee Summit. The opening session starts at ten in the morning in the main hall. Today we have meetings about the global coffee market, the new harvest, and export prices. Producers and partners from many countries are here. Please visit the company stands and share your name and email with new clients. Have a great summit.",
  "voice": "arthur",
  "file": "a1_listening1.mp3"
 },
 {
  "text": "Hi Fernanda, this is a voice message from the office. Welcome to the team. You work with our international clients now, so I send you the first contract by email today. We have a short meeting on Monday at nine. The coffee market is very busy this week. Please read the email and call me when you are ready. Thank you, and welcome to Sucafina.",
  "voice": "ellen",
  "file": "a1_listening2.mp3"
 },
 {
  "text": "Fernanda says her name at the summit. She says she works at Sucafina. Daniel talks about the international team. They talk about coffee and the market. They share email contacts and say goodbye.",
