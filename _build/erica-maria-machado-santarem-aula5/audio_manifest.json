 },
 {
  "text": "Hi, Erica! What do you do here at Biodelta?",
  "voice": "arthur",
  "file": "a5_hi_erica_what_do_you_do_here_at_biodelta.mp3"
 },
 {
  "text": "I work in the office. I write a report every week. What about you?",
  "voice": "ellen",
  "file": "a5_i_work_in_the_office_i_write_a_report_every_week.mp3"
 },
 {
  "text": "I am a project manager. I manage a new project this month.",
  "voice": "arthur",
  "file": "a5_i_am_a_project_manager_i_manage_a_new_project_th.mp3"
 },
 {
  "text": "Nice. What time do you start work?",
  "voice": "ellen",
  "file": "a5_nice_what_time_do_you_start_work.mp3"
 },
 {
  "text": "I start at half past eight, and I finish at six o'clock.",
  "voice": "arthur",
  "file": "a5_i_start_at_half_past_eight_and_i_finish_at_six_o.mp3"
 },
 {
  "text": "I send many emails and I answer the phone all day.",
  "voice": "ellen",
  "file": "a5_i_send_many_emails_and_i_answer_the_phone_all_da.mp3"
 },
 {
  "text": "You are a busy colleague! Do you like your job?",
  "voice": "arthur",
  "file": "a5_you_are_a_busy_colleague_do_you_like_your_job.mp3"
 },
 {
  "text": "Yes, I love my job. Biodelta is a great company.",
  "voice": "ellen",
  "file": "a5_yes_i_love_my_job_biodelta_is_a_great_company.mp3"
 },
 {
  "text": "I work at Biodelta.",
  "voice": "ellen",
  "file": "a5_i_work_at_biodelta.mp3"
 },
 {
  "text": "I start work at eight o'clock.",
  "voice": "arthur",
  "file": "a5_i_start_work_at_eight_o_clock.mp3"
 },
 {
  "text": "I send emails and I answer the phone.",
  "voice": "ellen",
  "file": "a5_i_send_emails_and_i_answer_the_phone.mp3"
 },
 {
  "text": "David is my colleague.",
  "voice": "arthur",
  "file": "a5_david_is_my_colleague.mp3"
 },
 {
  "text": "Hi, my name is Sofia. Let me tell you about my job. I work in a big office in the city. I am a manager. Every day, I start work at nine o'clock and I finish at half past five. I work with five colleagues. We work on many projects together. In the morning, I answer my emails and I write a report. In the afternoon, I have meetings with my team. I love my job, because every day is different.",
  "voice": "ellen",
  "file": "a5_listening1.mp3"
 },
 {
  "text": "Hello, I am Marcos. I want to tell you about my workday. I am a teacher. I work in a small school near my house. I start at seven o'clock in the morning. I teach four classes every day. I do not work in an office; I work in a classroom. After my classes, I answer the phone and I help the new students. I finish at three o'clock. My job is hard, but I am happy, because I help young people every day.",
  "voice": "arthur",
  "file": "a5_listening2.mp3"
 },
 {
  "text": "First, she starts work at eight o'clock. Second, she answers her emails. Third, she writes a report. Fourth, she works on the project with her colleague. Fifth, she finishes at five o'clock.",
  "voice": "ellen",
  "file": "pc5_order_l5.mp3"
