 },
 {
  "text": "I am Erica.",
  "voice": "ellen",
  "file": "a1_i_am_erica.mp3"
 },
 {
  "text": "She is from Sao Paulo.",
  "voice": "arthur",
  "file": "a1_she_is_from_sao_paulo.mp3"
 },
 {
  "text": "Biodelta is a company.",
  "voice": "ellen",
  "file": "a1_biodelta_is_a_company.mp3"
 },
 {
  "text": "We are colleagues.",
  "voice": "arthur",
  "file": "a1_we_are_colleagues.mp3"
 },
 {
  "text": "Hello! My name is David. I am the new lab manager.",
  "voice": "arthur",
  "file": "a1_hello_my_name_is_david_i_am_the_new_lab_manager.mp3"
 },
 {
  "text": "Hi David! Nice to meet you. I am Erica.",
  "voice": "ellen",
  "file": "a1_hi_david_nice_to_meet_you_i_am_erica.mp3"
 },
 {
  "text": "Nice to meet you too, Erica. Where are you from?",
  "voice": "arthur",
  "file": "a1_nice_to_meet_you_too_erica_where_are_you_from.mp3"
 },
 {
  "text": "I am from Sao Paulo. I live in Pinheiros. And you?",
  "voice": "ellen",
  "file": "a1_i_am_from_sao_paulo_i_live_in_pinheiros_and_you.mp3"
 },
 {
  "text": "I am from Canada, but now I live in Sao Paulo. What do you do here?",
  "voice": "arthur",
  "file": "a1_i_am_from_canada_but_now_i_live_in_sao_paulo_wha.mp3"
 },
 {
  "text": "I work at Biodelta. It is a biotechnology company.",
  "voice": "ellen",
  "file": "a1_i_work_at_biodelta_it_is_a_biotechnology_company.mp3"
 },
 {
  "text": "That is great! Do you like your job?",
  "voice": "arthur",
  "file": "a1_that_is_great_do_you_like_your_job.mp3"
 },
 {
  "text": "Yes, I do. I really like my work. Welcome to Biodelta, David!",
  "voice": "ellen",
  "file": "a1_yes_i_do_i_really_like_my_work_welcome_to_biodel.mp3"
 },
 {
  "text": "Hello, my name is Erica.",
  "voice": "ellen",
  "file": "a1_hello_my_name_is_erica.mp3"
 },
 {
  "text": "I am from Sao Paulo.",
  "voice": "arthur",
  "file": "a1_i_am_from_sao_paulo.mp3"
 },
 {
  "text": "I live in Pinheiros.",
  "voice": "ellen",
  "file": "a1_i_live_in_pinheiros.mp3"
 },
 {
  "text": "Nice to meet you.",
  "voice": "arthur",
  "file": "a1_nice_to_meet_you.mp3"
 },
 {
  "text": "Hello Erica, this is Marina from the Human Resources team at Biodelta. Welcome to the company! I am very happy to have you with us. Your first meeting is on Monday at nine in the morning. The team is friendly and they are excited to meet you. My office is on the third floor, next to the laboratory. If you have any questions, you can call me any time. See you on Monday. Have a great day!",
  "voice": "ellen",
  "file": "a1_listening1.mp3"
 },
 {
  "text": "Hi everyone, my name is Carlos. I am a researcher at Biodelta. I am from Rio de Janeiro, but I live in Sao Paulo now. I work in the laboratory every day with a great team. I really like my job because the work is interesting and important. In my free time, I play tennis and I read science books. It is very nice to meet all of you.",
  "voice": "arthur",
  "file": "a1_listening2.mp3"
 },
 {
  "text": "First, say hello and your name. Second, say where you are from. Third, say where you live. Fourth, say where you work. Fifth, say nice to meet you.",
