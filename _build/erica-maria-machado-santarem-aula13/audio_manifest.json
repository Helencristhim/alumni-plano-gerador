 },
 {
  "text": "I like reading books and listening to music.",
  "voice": "ellen",
  "file": "a13_i_like_reading_books_and_listening_to_music.mp3"
 },
 {
  "text": "Nice! I enjoy cooking. Do you like cooking too?",
  "voice": "arthur",
  "file": "a13_nice_i_enjoy_cooking_do_you_like_cooking_too.mp3"
 },
 {
  "text": "Yes, I do. And I love gardening on Sunday.",
