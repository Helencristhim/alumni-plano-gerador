 },
 {
  "text": "Hi! You must be the new engineer. I am Rachel. Welcome to the team!",
  "voice": "ellen",
  "file": "a1_hi_you_must_be_the_new_engineer_i_am_rachel_welc.mp3"
 },
 {
  "text": "Hi Rachel! Yes, I am Danilo. Nice to meet you.",
  "voice": "arthur",
  "file": "a1_hi_rachel_yes_i_am_danilo_nice_to_meet_you.mp3"
 },
 {
  "text": "Nice to meet you too! So, what do you do here?",
  "voice": "ellen",
  "file": "a1_nice_to_meet_you_too_so_what_do_you_do_here.mp3"
 },
 {
  "text": "I am a data engineer. I work on the data team. What about you?",
  "voice": "arthur",
  "file": "a1_i_am_a_data_engineer_i_work_on_the_data_team_wha.mp3"
 },
 {
  "text": "I am a product manager. I work in the same department. Where are you from?",
  "voice": "ellen",
  "file": "a1_i_am_a_product_manager_i_work_in_the_same_depart.mp3"
 },
 {
  "text": "I am from São Paulo. And you?",
  "voice": "arthur",
  "file": "a1_i_am_from_sao_paulo_and_you.mp3"
 },
 {
  "text": "I am from Rio, but I live here now. Do you like the office?",
  "voice": "ellen",
  "file": "a1_i_am_from_rio_but_i_live_here_now_do_you_like_th.mp3"
 },
 {
  "text": "Yes, I like it a lot. Everyone is very friendly.",
  "voice": "arthur",
  "file": "a1_yes_i_like_it_a_lot_everyone_is_very_friendly.mp3"
 },
 {
  "text": "Great! Let me show you the kitchen. We have good coffee here!",
  "voice": "ellen",
  "file": "a1_great_let_me_show_you_the_kitchen_we_have_good_c.mp3"
 },
 {
  "text": "Perfect. Thank you, Rachel!",
  "voice": "arthur",
  "file": "a1_perfect_thank_you_rachel.mp3"
 },
 {
  "text": "Hi, I am Danilo. Nice to meet you.",
  "voice": "arthur",
  "file": "a1_hi_i_am_danilo_nice_to_meet_you.mp3"
 },
 {
  "text": "I am a data engineer. I work on the data team.",
  "voice": "ellen",
  "file": "a1_i_am_a_data_engineer_i_work_on_the_data_team.mp3"
 },
 {
  "text": "I work at a tech company in São Paulo.",
  "voice": "arthur",
  "file": "a1_i_work_at_a_tech_company_in_sao_paulo.mp3"
 },
 {
  "text": "My manager is Marcus. He is very friendly.",
  "voice": "ellen",
  "file": "a1_my_manager_is_marcus_he_is_very_friendly.mp3"
 },
 {
  "text": "Hi Danilo, and welcome to the company! My name is Sofia, from the people team. I am very happy to have you here. Let me tell you a few things about your first day. Your desk is on the third floor, next to the data team. Your manager is called Marcus, and he is very friendly. We start work at nine o'clock, and we have lunch at noon. On Monday mornings, the whole team meets for thirty minutes. If you have any questions, just ask. Everyone here is happy to help. Have a great first day!",
  "voice": "ellen",
  "file": "a1_listening_welcome.mp3"
 },
